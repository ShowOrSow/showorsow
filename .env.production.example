# ShowOrSow — PRODUCTION env template (VPS backend + indexer).
# Copy to the server and fill the <...> values. NEVER commit the filled file.
# ---------------------------------------------------------------------------

# === Ledger (Canton DevNet, via the HackCanton shared node) =================
# The participant's JSON Ledger API v2 endpoint (ask @mrlp8 for the URL).
LEDGER_JSON_API_URL=https://<hackcanton-devnet-participant>/
# WebSocket updates endpoint for the indexer (ws/wss). Blank → derived from above.
LEDGER_WS_URL=

# DevNet is authenticated. Operator mode: ONE participant-wide token acts as
# every user party our participant hosts (13-deployment). Provide EITHER a
# static token OR operator-wide Keycloak refresh:
LEDGER_OPERATOR_JWT=<participant-operator-jwt-that-can-actAs-hosted-parties>
LEDGER_OPERATOR_WIDE=false            # true → refresh via the KEYCLOAK_* below for all parties
KEYCLOAK_HOST=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID_APPOPERATOR=
KEYCLOAK_CLIENT_SECRET_APPOPERATOR=
KEYCLOAK_USERNAME_APPOPERATOR=
KEYCLOAK_PASSWORD_APPOPERATOR=

# The app's own party on DevNet (executor + faucet issuer). From Console Wallet.
PARTY_APPOPERATOR=appoperator::1220<...>

# === Database (Neon, serverless Postgres — pooled connection string) =========
NEON_DATABASE_URL=postgres://<user>:<pass>@ep-<...>-pooler.<region>.aws.neon.tech/showorsow?sslmode=require

# === Backend server =========================================================
LISTEN_ADDR=:8080
INDEXER_HEALTH_URL=http://127.0.0.1:8091
# HMAC session secret — generate: openssl rand -hex 32
SESSION_SECRET=<64-hex-chars>
# HTTPS in prod (behind Caddy + the Vercel proxy) → Secure cookies.
COOKIE_SECURE=true
# CORS allowlist: the Vercel web origin (the browser reaches the API same-origin
# via Vercel's /api rewrite, so this is a belt-and-braces allow).
WEB_ORIGIN=https://<your-app>.vercel.app
SETTLE_BUFFER=24h

# === Demo access for judges =================================================
SEED_DEMO_USERS=true                  # seed Organizer/Alice/Bob/Charlie on boot
DEV_QUICK_LOGIN=true                  # one-click demo login on /login
DEV_FAUCET=true                       # in-app "Get test tokens" (SHOW)
FAUCET_ISSUER_PARTY=                  # blank → PARTY_APPOPERATOR (DemoIssuer signatory)
FAUCET_AMOUNT=10.0

# === Tokens =================================================================
# SHOW = the self-contained demo token (upload showorsow-demo-token.dar first;
# admin/issuer = appOperator party). The cBTC/cETH entries are DevNet registry
# tokens (mintable:false → the UI opens their faucet instead of minting); their
# adminParty/instrumentId/decimals were verified live on 2026-07-23. They only
# work once the backend points at a DevNet participant AND our party holds the
# token, so keep them commented out while running against the local sandbox.
TOKENS=[{"label":"SHOW","adminParty":"appoperator::1220<...>","instrumentId":"SHOW","mintable":true}]

# --- DevNet cutover: replace the line above with this one. -------------------
# TOKENS=[{"label":"cBTC","adminParty":"cbtc-network::12202a83c6f4082217c175e29bc53da5f2703ba2675778ab99217a5a881a949203ff","instrumentId":"CBTC","registryBaseUrl":"https://api.utilities.digitalasset-dev.com/api/token-standard/v0/registrars/cbtc-network::12202a83c6f4082217c175e29bc53da5f2703ba2675778ab99217a5a881a949203ff/registry","faucetUrl":"https://cbtc-faucet.bitsafe.finance/"},{"label":"cETH","adminParty":"rails-cethMain-1-dev::12200b6de051e66bacd250de4bc76292e9d0ef71b478d7c11e49799b8e26f853493e","instrumentId":"cETH","registryBaseUrl":"https://api.utilities.digitalasset-dev.com/api/token-standard/v0/registrars/rails-cethMain-1-dev::12200b6de051e66bacd250de4bc76292e9d0ef71b478d7c11e49799b8e26f853493e/registry","faucetUrl":"https://forms.gle/qY1Eq4AxuTFrxf49A"},{"label":"SHOW","adminParty":"appoperator::1220<...>","instrumentId":"SHOW","mintable":true}]

# === Indexer (same ledger + DB; streams as appOperator) =====================
INDEXER_PARTY=appoperator::1220<...>
INDEXER_JWT=<same operator jwt as LEDGER_OPERATOR_JWT>
INDEXER_HEALTH_PORT=8091
INDEXER_POLL_INTERVAL_MS=2000
