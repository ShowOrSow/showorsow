-- | MockRegistry — a minimal in-memory CIP-56 registry for `dpm test` ONLY.
--
-- This package is TEST-ONLY and must never ship (plan/04-smart-contract.md §1.6).
-- It implements just enough of the token standard for the demo narrative:
--   * MockHolding          — a toy Holding (owner + instrument + amount).
--   * MockAllocation       — implements the Allocation interface with working
--                            Allocation_ExecuteTransfer (slash → receiver holding) and
--                            Allocation_Cancel (refund → sender holding).
--   * MockAllocationFactory — an `Allocate` choice that mimics the wallet's
--                            AllocationFactory_Allocate: consumes the sender's holding
--                            and produces a MockAllocation backing the requested leg.
-- No expiry, no Allocation_Withdraw path — only what the happy path + edge tests exercise.
module MockRegistry where

import DA.Assert ((===))

import Splice.Api.Token.MetadataV1 (emptyMetadata)
import Splice.Api.Token.HoldingV1
  ( Holding
  , HoldingView(..)
  , InstrumentId(..)
  )
-- Unqualified: the `interface instance Allocation for MockAllocation` block below must
-- define the interface methods `allocation_executeTransferImpl` / `allocation_cancelImpl`
-- / `allocation_withdrawImpl`, which are top-level identifiers not covered by any
-- `Allocation(..)` shorthand. A bare import brings them plus all the record/result types.
import Splice.Api.Token.AllocationV1

-- ---------------------------------------------------------------------------
-- MockHolding — a toy asset position implementing the Holding interface.
-- ---------------------------------------------------------------------------
template MockHolding
  with
    admin : Party        -- instrument admin (registry)
    owner : Party
    instrId : Text
    amount : Decimal
  where
    -- Signed by the admin (registry) ONLY, so `admin` can mint test holdings as a faucet
    -- without collecting the owner's signature; the owner is an observer so they can see
    -- and reference their holding cid. (A real registry Holding is admin-authored too.)
    signatory admin
    observer owner

    interface instance Holding for MockHolding where
      view = HoldingView with
        owner
        instrumentId = InstrumentId with admin, id = instrId
        amount
        lock = None
        meta = emptyMetadata

-- ---------------------------------------------------------------------------
-- MockAllocation — implements the Allocation interface.
--   ExecuteTransfer: mints a MockHolding for the receiver (the slash → pot).
--   Cancel:          mints a MockHolding back to the sender (the refund).
-- The interface choices are controlled by [executor, sender, receiver]; that authority
-- is supplied at settle time by StakedRSVP.Settle, whose signatory set
-- (attendee + organizer + appOperator) covers executor(appOperator) + sender(attendee) +
-- receiver(appOperator). See the signatory note on the template itself for why the
-- contract is signed by admin + sender only (create-time authority).
-- ---------------------------------------------------------------------------
template MockAllocation
  with
    admin : Party
    spec : AllocationSpecification
  where
    -- Signed by admin + sender (mirrors AmuletAllocation: instrument admin + sender).
    -- The receiver is an OBSERVER, not a signatory: creating this contract inside
    -- MockAllocationFactory.Allocate (controller = sender, factory signed by admin)
    -- must be authorized by only admin + sender. The receiver's authority is NOT needed
    -- to CREATE the allocation — it is needed to EXERCISE Allocation_ExecuteTransfer/Cancel,
    -- and that authority is supplied at settle time by StakedRSVP's signatory set
    -- (attendee + organizer + appOperator covers executor + sender + receiver).
    signatory admin, spec.transferLeg.sender
    observer spec.transferLeg.receiver

    interface instance Allocation for MockAllocation where
      view = AllocationView with
        allocation = spec
        holdingCids = []
        meta = emptyMetadata

      allocation_executeTransferImpl _self _arg = do
        -- Slash: deliver the staked amount to the receiver (the pot).
        newHolding <- create MockHolding with
          admin
          owner = spec.transferLeg.receiver
          instrId = spec.transferLeg.instrumentId.id
          amount = spec.transferLeg.amount
        pure Allocation_ExecuteTransferResult with
          senderHoldingCids = []
          receiverHoldingCids = [toInterfaceContractId newHolding]
          meta = emptyMetadata

      allocation_cancelImpl _self _arg = do
        -- Refund: return the staked amount to the sender.
        newHolding <- create MockHolding with
          admin
          owner = spec.transferLeg.sender
          instrId = spec.transferLeg.instrumentId.id
          amount = spec.transferLeg.amount
        pure Allocation_CancelResult with
          senderHoldingCids = [toInterfaceContractId newHolding]
          meta = emptyMetadata

      allocation_withdrawImpl _self _arg = do
        -- Not exercised by the demo; refund to sender for completeness.
        newHolding <- create MockHolding with
          admin
          owner = spec.transferLeg.sender
          instrId = spec.transferLeg.instrumentId.id
          amount = spec.transferLeg.amount
        pure Allocation_WithdrawResult with
          senderHoldingCids = [toInterfaceContractId newHolding]
          meta = emptyMetadata

-- ---------------------------------------------------------------------------
-- MockAllocationFactory — stands in for the registry's AllocationFactory.
-- The `Allocate` choice is controlled by the leg sender (the attendee), mirroring
-- AllocationFactory_Allocate's controller, and returns a MockAllocation cid coerced
-- to the Allocation interface (what RecordAllocation expects).
-- ---------------------------------------------------------------------------
template MockAllocationFactory
  with
    admin : Party
    -- Parties allowed to see (and thus exercise) the factory. In production the registry
    -- discloses the factory off-ledger; for the mock we simply make prospective senders
    -- observers so `submit attendee (exerciseCmd factory Allocate ...)` can find it.
    senders : [Party]
  where
    signatory admin
    observer senders

    nonconsuming choice Allocate : ContractId Allocation
      with
        spec : AllocationSpecification
        holdingCid : ContractId MockHolding
      controller spec.transferLeg.sender
      do
        -- Validate the funding holding matches the leg, then consume it (funds "locked").
        h <- fetch holdingCid
        h.owner === spec.transferLeg.sender
        h.amount === spec.transferLeg.amount
        h.instrId === spec.transferLeg.instrumentId.id
        archive holdingCid
        allocCid <- create MockAllocation with admin, spec
        pure (toInterfaceContractId allocCid)
