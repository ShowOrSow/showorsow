{
  "name": "showorsow-indexer",
  "version": "0.1.0",
  "private": true,
  "description": "ShowOrSow ledger indexer — projects JSON Ledger API v2 update stream into Neon (read-only on the ledger)",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "node --experimental-strip-types src/main.ts",
    "migrate": "node --experimental-strip-types src/migrate.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --test src/handlers.test.ts"
  },
  "dependencies": {
    "pg": "^8.13.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.2"
  }
}
