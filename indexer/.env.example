# ShowOrSow indexer — local env (backend's .env minus write creds; read-only on the ledger)

# --- Neon / Postgres ---
DATABASE_URL=postgres://user:password@ep-xxxx.us-east-2.aws.neon.tech/showorsow?sslmode=require

# --- JSON Ledger API v2 (as appOperator) ---
# HTTP base for active-contracts polling fallback + ledger-end
LEDGER_HTTP_BASE=http://localhost:7575
# WebSocket base for the update stream (AsyncAPI). ws:// local sandbox, wss:// DevNet.
LEDGER_WS_BASE=ws://localhost:7575
# appOperator party id (the indexer only sees what this party is entitled to see)
APP_OPERATOR_PARTY=appOperator::1220xxxx
# Bearer JWT for appOperator. Sandbox = empty (unauthenticated). DevNet = Keycloak token.
LEDGER_JWT=

# --- Pot party (settlement receiver — 04 §1.4: receiver = appOperator {- pot -}) ---
# Party whose Holding creates/archives are the pot in/outflows (E15/E15b). Defaults to appOperator.
POT_PARTY=appOperator::1220xxxx

# --- Stream mode ---
# 'ws' (primary, JSON API v2 updates WebSocket) or 'poll' (active-contracts diffing fallback, 06 §3)
STREAM_MODE=ws
# Polling fallback tick in ms (06 §3: 2s tick)
POLL_INTERVAL_MS=2000

# --- healthz HTTP endpoint (backend proxies into GET /api/session for StaleBadge) ---
HEALTHZ_PORT=8081

# --- Qualified template/interface names (package-id-agnostic; matched by qualified name, 06 §1) ---
# module:Entity — DevNet resets change package ids so we NEVER match on package id.
TPL_EVENT=ShowOrSow:Event
TPL_EVENT_PROPOSAL=ShowOrSow:EventProposal
TPL_RSVP_INVITE=ShowOrSow:RSVPInvite
TPL_STAKED_RSVP=ShowOrSow:StakedRSVP
IFACE_ALLOCATION=Splice.Api.Token.AllocationV1:Allocation
IFACE_TRANSFER_INSTRUCTION=Splice.Api.Token.TransferInstructionV1:TransferInstruction
IFACE_HOLDING=Splice.Api.Token.HoldingV1:Holding

# --- Interface WIRE filter ids (package-qualified; sent to the server's InterfaceFilter, 04 §2) ---
# The server needs a package-qualified id ('#pkg-name:Module:Entity' or 'pkgId:Module:Entity'); the
# bare 'Module:Entity' above is only the package-agnostic MATCH name the decoder uses. Confirm the
# exact package names against a real 3.4.x sandbox / dpm codegen output.
IFACE_ALLOCATION_WIRE=#splice-api-token-allocation-v1:Splice.Api.Token.AllocationV1:Allocation
IFACE_TRANSFER_INSTRUCTION_WIRE=#splice-api-token-transfer-instruction-v1:Splice.Api.Token.TransferInstructionV1:TransferInstruction
IFACE_HOLDING_WIRE=#splice-api-token-holding-v1:Splice.Api.Token.HoldingV1:Holding

# meta key the payout runner stamps eventId under (E13; 05 §5)
META_EVENT_KEY=showorsow.dev/event
