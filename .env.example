# ShowOrSow — root .env.example
# Covers backend (Go), indexer (TS), and web (Next.js) variables.
# Copy to .env (gitignored) and fill in. Re-fetch token/party facts at BUILD
# TIME — DevNet resets without notice (03-tech-stack.md §1 §6).
# ---------------------------------------------------------------------------

# ===========================================================================
# SHARED — ledger + database (backend + indexer both read these)
# ===========================================================================

# JSON Ledger API v2 base URL. Sandbox: pass --json-api-port 7575 (JSON API is
# OFF by default). LocalNet/DevNet: the participant's JSON API endpoint.
LEDGER_JSON_API_URL=http://localhost:7575

# Optional synchronizer (domain) id attached to command submissions. Leave
# blank on single-domain sandbox.
SYNCHRONIZER_ID=

# Neon / Postgres connection string (read model + off-chain store).
# Backend writes event_meta + balance_snapshots; indexer writes everything else.
NEON_DATABASE_URL=postgres://user:pass@ep-xxxx.neon.tech/showorsow?sslmode=require

# ===========================================================================
# BACKEND (Go) — cmd/server
# ===========================================================================

# HTTP listen address for the backend API.
LISTEN_ADDR=:8080

# Indexer healthz base URL — backend proxies {INDEXER_HEALTH_URL}/healthz into
# GET /api/session as indexerLagMs (feeds the StaleBadge). Leave blank to
# report lag = -1 (unknown).
INDEXER_HEALTH_URL=http://localhost:8091

# Settlement buffer added to eventEnd to derive settleBefore. Go duration.
SETTLE_BUFFER=24h

# R6 fallback: when true, CloseEvent is exercised once per RSVP with a
# single-item settleItems list ("settlement round") instead of one atomic
# exercise. Flip to true only if registries reject N allocation executions in
# one transaction (09-risks.md R6).
SETTLE_SEQUENTIAL_FALLBACK=false

# HMAC secret for the demo-grade signed session cookie. CHANGE in any shared
# environment. (Auth is deliberately demo-grade — see 05-backend.md §2.)
SESSION_SECRET=change-me-to-a-long-random-string

# --- Auth (Luma-style real accounts, pivot Jul 11 — replaces the persona
# --- switcher). Every registered user gets their OWN Canton party, allocated at
# --- signup via POST /v2/parties. Only appOperator (below) is env-configured.

# Enable the one-click demo quick-login strip on /login (POST /api/auth/dev-login
# for seeded demo accounts ONLY). Also surfaced unauthenticated at GET /api/config
# so the /login page can probe it pre-session. Turn OFF in anything shared.
DEV_QUICK_LOGIN=true

# Idempotently seed the 4 demo accounts on startup (Organizer/Alice/Bob/Charlie;
# emails PINNED to the frontend strip: organizer@showorsow.dev, alice@…, bob@…,
# charlie@…; password demo1234; is_demo=true; a party allocated per account on
# first creation). Safe to leave on — existing accounts are left untouched.
SEED_DEMO_USERS=true

# Uploaded main-package id for our own templates. Leave BLANK to use the
# package-name form (#showorsow:Module:Entity), which is DevNet-reset resilient.
# Set to the concrete package id only if the participant does not resolve the
# #name form.
SHOWOROSOW_PACKAGE_ID=

# --- Tokens (JSON array). decimals are NOT listed here — they are read live
# --- from the registry metadata endpoint (03 §1: never bake token decimals).
# --- Treat (adminParty, instrumentId) as opaque config. registryBaseUrl is the
# --- .../registrars/{admin}/registry base (03 §6). Re-fetch party ids at build.
# ---
# --- Per-token faucet fields (05 §6c, added Jul 12):
# ---   mintable:true + issuerParty  → the SHOW demo token: POST /api/faucet mints
# ---     it on-ledger via DemoIssuer.Mint (no external faucet, no registry HTTP;
# ---     stake + settlement run in demo-token mode). instrumentId.admin = issuer.
# ---   faucetUrl (registry tokens)  → the external faucet the UI opens for the
# ---     user to paste their party; the deposit acceptor (§6b) catches the
# ---     incoming CIP-56 transfer. Falls back to the BitSafe faucet when unset.
# --- The SHOW entry below is deployed ONLY in demo/dev (its own DAR, 04 §1.7);
# --- set its adminParty/issuerParty to the deployed DemoIssuer party.
TOKENS=[{"label":"cBTC","adminParty":"cbtc-network::12202a83c6f4082217c175e29bc53da5f2703ba2675778ab99217a5a881a949203ff","instrumentId":"CBTC","registryBaseUrl":"https://api.utilities.digitalasset-dev.com/api/token-standard/v0/registrars/cbtc-network::12202a83c6f4082217c175e29bc53da5f2703ba2675778ab99217a5a881a949203ff/registry","faucetUrl":"https://faucet.bitsafe.dev/"},{"label":"cETH","adminParty":"rails-cethMain-1-dev::12200b6de051e66bacd250de4bc76292e9d0ef71b478d7c11e49799b8e26f853493e","instrumentId":"cETH","registryBaseUrl":"https://api.utilities.digitalasset-dev.com/api/token-standard/v0/registrars/rails-cethMain-1-dev::12200b6de051e66bacd250de4bc76292e9d0ef71b478d7c11e49799b8e26f853493e/registry","faucetUrl":"https://faucet.bitsafe.dev/"},{"label":"SHOW","adminParty":"appoperator::1220bbbb...","instrumentId":"SHOW","registryBaseUrl":"","mintable":true,"issuerParty":"appoperator::1220bbbb..."}]

# --- Faucet (in-app test tokens, 05 §6c). DEV_FAUCET gates POST /api/faucet and
# --- is surfaced unauthenticated at GET /api/config so the UI can show/hide the
# --- affordance. Turn OFF in anything shared.
DEV_FAUCET=true
# DemoIssuer signatory the mint runs as when a mintable token carries no per-token
# issuerParty. Defaults to PARTY_APPOPERATOR (a single-party demo where appOperator
# is also the issuer works out of the box); set to a dedicated issuer if separated.
FAUCET_ISSUER_PARTY=
# Default mint amount when POST /api/faucet omits one.
FAUCET_AMOUNT=1.0

# --- appOperator party. The app's OWN Canton party — NOT a user. It carries the
# --- ledger-write token and authorises signup party allocation (POST /v2/parties).
# --- Registered users' parties are allocated at signup and stored in the `users`
# --- table, never here. Re-fetch the party id at build (DevNet resets).
PARTY_APPOPERATOR=appoperator::1220bbbb...

# --- appOperator ledger auth. Three modes:
#  (a) Sandbox (unauthenticated): leave JWT_APPOPERATOR and the KEYCLOAK_* block
#      blank — the backend sends no Authorization header. Users act unauthenticated
#      as their own parties too.
#  (b) Static/pre-minted token: set JWT_APPOPERATOR and it is used verbatim.
#  (c) Keycloak password grant (LocalNet/DevNet): set KEYCLOAK_HOST + the
#      appOperator client/username below and the backend refreshes the token.
# NOTE: per-user DevNet JWTs are a documented MVP limitation (05 §2) — the backend
# holds a ledger token ONLY for appOperator; user parties resolve to no token.
JWT_APPOPERATOR=

# --- Keycloak password grant for appOperator (LocalNet/DevNet). KEYCLOAK_HOST may
# --- include the legacy /auth context root — match what the participant exposes.
KEYCLOAK_HOST=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
# appOperator-specific overrides (optional; fall back to the shared client above):
KEYCLOAK_CLIENT_ID_APPOPERATOR=
KEYCLOAK_CLIENT_SECRET_APPOPERATOR=
KEYCLOAK_USERNAME_APPOPERATOR=
KEYCLOAK_PASSWORD_APPOPERATOR=

# ===========================================================================
# INDEXER (TS) — subscribes to the ledger stream as appOperator, projects to
# Neon. "Backend's env minus write creds" (06 §5). Reads LEDGER_JSON_API_URL,
# NEON_DATABASE_URL, SYNCHRONIZER_ID above, plus:
# ===========================================================================

# appOperator JWT the indexer streams under (read-only on the ledger). On
# sandbox leave blank.
INDEXER_JWT=
INDEXER_PARTY=appoperator::1220bbbb...

# WebSocket updates endpoint (defaults to LEDGER_JSON_API_URL with ws scheme if
# blank). Set explicitly if the participant exposes a distinct WS host.
LEDGER_WS_URL=

# Indexer healthz listen port (backend's INDEXER_HEALTH_URL points here).
INDEXER_HEALTH_PORT=8091

# Poll fallback tick (ms) if the WS stream is flaky (06 §3).
INDEXER_POLL_INTERVAL_MS=2000

# ===========================================================================
# WEB (Next.js) — talks ONLY to the backend, never the ledger (08 §intro).
# ===========================================================================

# Base URL of the Go backend API. Exposed to the browser (NEXT_PUBLIC_*).
NEXT_PUBLIC_API_URL=http://localhost:8080

# SWR poll interval (ms) on detail pages during the demo (08 §4).
NEXT_PUBLIC_POLL_INTERVAL_MS=2000
