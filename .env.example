# ShowOrSow — root .env.example
# Covers backend (Go), indexer (TS), and web (Next.js) variables.
# Copy to .env (gitignored) and fill in. Re-fetch token/party facts at BUILD
# TIME — DevNet resets without notice (03-tech-stack.md §1 §6).
# ---------------------------------------------------------------------------

# ===========================================================================
# SHARED — ledger + database (backend + indexer both read these)
# ===========================================================================

# JSON Ledger API v2 base URL. Sandbox: pass --json-api-port 7575 (JSON API is
# OFF by default). LocalNet/DevNet: the participant's JSON API endpoint.
LEDGER_JSON_API_URL=http://localhost:7575

# Optional synchronizer (domain) id attached to command submissions. Leave
# blank on single-domain sandbox.
SYNCHRONIZER_ID=

# Neon / Postgres connection string (read model + off-chain store).
# Backend writes event_meta + balance_snapshots; indexer writes everything else.
NEON_DATABASE_URL=postgres://user:pass@ep-xxxx.neon.tech/showorsow?sslmode=require

# ===========================================================================
# BACKEND (Go) — cmd/server
# ===========================================================================

# HTTP listen address for the backend API.
LISTEN_ADDR=:8080

# Indexer healthz base URL — backend proxies {INDEXER_HEALTH_URL}/healthz into
# GET /api/session as indexerLagMs (feeds the StaleBadge). Leave blank to
# report lag = -1 (unknown).
INDEXER_HEALTH_URL=http://localhost:8091

# Settlement buffer added to eventEnd to derive settleBefore. Go duration.
SETTLE_BUFFER=24h

# R6 fallback: when true, CloseEvent is exercised once per RSVP with a
# single-item settleItems list ("settlement round") instead of one atomic
# exercise. Flip to true only if registries reject N allocation executions in
# one transaction (09-risks.md R6).
SETTLE_SEQUENTIAL_FALLBACK=false

# HMAC secret for the demo-grade signed session cookie. CHANGE in any shared
# environment. (Auth is deliberately demo-grade — see 05-backend.md §2.)
SESSION_SECRET=change-me-to-a-long-random-string

# Well-known persona names (rarely changed).
APP_OPERATOR_PERSONA=appoperator
ORGANIZER_PERSONA=organizer

# Uploaded main-package id for our own templates. Leave BLANK to use the
# package-name form (#showorsow:Module:Entity), which is DevNet-reset resilient.
# Set to the concrete package id only if the participant does not resolve the
# #name form.
SHOWOROSOW_PACKAGE_ID=

# --- Tokens (JSON array). decimals are NOT listed here — they are read live
# --- from the registry metadata endpoint (03 §1: never bake token decimals).
# --- Treat (adminParty, instrumentId) as opaque config. registryBaseUrl is the
# --- .../registrars/{admin}/registry base (03 §6). Re-fetch party ids at build.
TOKENS=[{"label":"cBTC","adminParty":"cbtc-network::12202a83c6f4082217c175e29bc53da5f2703ba2675778ab99217a5a881a949203ff","instrumentId":"CBTC","registryBaseUrl":"https://api.utilities.digitalasset-dev.com/api/token-standard/v0/registrars/cbtc-network::12202a83c6f4082217c175e29bc53da5f2703ba2675778ab99217a5a881a949203ff/registry"},{"label":"cETH","adminParty":"rails-cethMain-1-dev::12200b6de051e66bacd250de4bc76292e9d0ef71b478d7c11e49799b8e26f853493e","instrumentId":"cETH","registryBaseUrl":"https://api.utilities.digitalasset-dev.com/api/token-standard/v0/registrars/rails-cethMain-1-dev::12200b6de051e66bacd250de4bc76292e9d0ef71b478d7c11e49799b8e26f853493e/registry"}]

# --- Personas: party id per persona (PARTY_<UPPERNAME>). Re-fetch at build.
# --- The five demo personas: organizer, appoperator, attendee1..3.
PARTY_ORGANIZER=organizer::1220aaaa...
PARTY_APPOPERATOR=appoperator::1220bbbb...
PARTY_ATTENDEE1=attendee1::1220cccc...
PARTY_ATTENDEE2=attendee2::1220dddd...
PARTY_ATTENDEE3=attendee3::1220eeee...

# --- Persona JWTs. Two modes:
#  (a) Sandbox (unauthenticated): leave BOTH the JWT_* and KEYCLOAK_* blocks
#      blank — the backend sends no Authorization header.
#  (b) Static/pre-minted tokens: set JWT_<UPPERNAME> and the backend uses it
#      verbatim (no refresh).
JWT_ORGANIZER=
JWT_APPOPERATOR=
JWT_ATTENDEE1=
JWT_ATTENDEE2=
JWT_ATTENDEE3=

# --- Keycloak password grant (LocalNet/DevNet). If KEYCLOAK_HOST is set and a
# --- persona has a username, the backend obtains + refreshes JWTs per persona.
# --- KEYCLOAK_HOST may include the legacy /auth context root — match what the
# --- participant exposes (03 §4).
KEYCLOAK_HOST=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
# Per-persona overrides (optional; fall back to the shared client above):
KEYCLOAK_USERNAME_ORGANIZER=
KEYCLOAK_PASSWORD_ORGANIZER=
KEYCLOAK_USERNAME_APPOPERATOR=
KEYCLOAK_PASSWORD_APPOPERATOR=
KEYCLOAK_USERNAME_ATTENDEE1=
KEYCLOAK_PASSWORD_ATTENDEE1=
KEYCLOAK_USERNAME_ATTENDEE2=
KEYCLOAK_PASSWORD_ATTENDEE2=
KEYCLOAK_USERNAME_ATTENDEE3=
KEYCLOAK_PASSWORD_ATTENDEE3=

# ===========================================================================
# INDEXER (TS) — subscribes to the ledger stream as appOperator, projects to
# Neon. "Backend's env minus write creds" (06 §5). Reads LEDGER_JSON_API_URL,
# NEON_DATABASE_URL, SYNCHRONIZER_ID above, plus:
# ===========================================================================

# appOperator JWT the indexer streams under (read-only on the ledger). On
# sandbox leave blank.
INDEXER_JWT=
INDEXER_PARTY=appoperator::1220bbbb...

# WebSocket updates endpoint (defaults to LEDGER_JSON_API_URL with ws scheme if
# blank). Set explicitly if the participant exposes a distinct WS host.
LEDGER_WS_URL=

# Indexer healthz listen port (backend's INDEXER_HEALTH_URL points here).
INDEXER_HEALTH_PORT=8091

# Poll fallback tick (ms) if the WS stream is flaky (06 §3).
INDEXER_POLL_INTERVAL_MS=2000

# ===========================================================================
# WEB (Next.js) — talks ONLY to the backend, never the ledger (08 §intro).
# ===========================================================================

# Base URL of the Go backend API. Exposed to the browser (NEXT_PUBLIC_*).
NEXT_PUBLIC_API_URL=http://localhost:8080

# SWR poll interval (ms) on detail pages during the demo (08 §4).
NEXT_PUBLIC_POLL_INTERVAL_MS=2000
